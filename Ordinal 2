def compute_saliency(model_for_saliency, sig_np, target_class=None):
    model_for_saliency.eval()

    x = torch.tensor(sig_np[None, :, :], dtype=torch.float32, device=device, requires_grad=True)
    logits = model_for_saliency(x)
    threshold_probs = torch.sigmoid(logits)
    pred_class = int(torch.sum(threshold_probs > 0.5, dim=1).item())

    if target_class is None:
        target_class = pred_class

    if target_class == 0:
        score = 1.0 - threshold_probs[0, 0]
    elif target_class == num_classes - 1:
        score = threshold_probs[0, -1]
    else:
        score = threshold_probs[0, target_class - 1] - threshold_probs[0, target_class]

    model_for_saliency.zero_grad()
    score.backward()

    sal = x.grad.detach().abs().cpu().numpy()[0]
    sal = sal / (sal.max() + 1e-8)
    return sal, pred_class

def pick_representative_correct_example(frame_with_preds, preferred_class=None):
    frame = frame_with_preds.copy()

    if preferred_class is not None:
        cand = frame[(frame["correct"]) & (frame["y_true"] == preferred_class)].copy()
    else:
        cand = frame[frame["correct"]].copy()

    if len(cand) == 0:
        cand = frame.copy()

    cand = cand.sort_values("max_prob", ascending=False)
    return cand.iloc[0]

def plot_saliency_figure(row, save_path, model_for_saliency):
    sig = load_and_normalize_signal(
        row["record_path"],
        expected_len=1000,
        select_leads=SELECT_LEADS
    )
    sal, pred_class = compute_saliency(model_for_saliency, sig, target_class=int(row["y_true"]))

    top_leads = np.argsort(sal.mean(axis=1))[::-1][:len(DISPLAY_LEAD_NAMES)]

    fig = plt.figure(figsize=(12, 8))
    gs = fig.add_gridspec(3, 1, height_ratios=[1.5, 1, 1])

    ax0 = fig.add_subplot(gs[0, 0])
    ax0.imshow(sal, aspect="auto", origin="lower")
    ax0.set_yticks(range(len(DISPLAY_LEAD_NAMES)))
    ax0.set_yticklabels(DISPLAY_LEAD_NAMES)
    ax0.set_xlabel("Time samples (100 Hz)")
    ax0.set_title(
        f"Saliency heatmap | True={idx_to_class[int(row['y_true'])]} | Pred={idx_to_class[pred_class]}"
    )

    t = np.arange(sig.shape[1]) / 100.0
    for plot_idx, lead_idx in enumerate(top_leads, start=1):
        ax = fig.add_subplot(gs[plot_idx, 0])
        ax.plot(t, sig[lead_idx], linewidth=1.0)
        overlay = sal[lead_idx]
        scaled_overlay = (overlay / (overlay.max() + 1e-8)) * (sig[lead_idx].max() - sig[lead_idx].min()) * 0.3
        ax.fill_between(t, sig[lead_idx].min(), sig[lead_idx].min() + scaled_overlay, alpha=0.35)
        ax.set_title(f"Lead {DISPLAY_LEAD_NAMES[lead_idx]} (mean saliency={sal[lead_idx].mean():.3f})")
        ax.set_xlabel("Time (s)")
        ax.set_ylabel("z-score")

    plt.tight_layout()
    plt.savefig(save_path, dpi=300, bbox_inches="tight")
    plt.show()


